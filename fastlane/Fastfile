default_platform(:ios)

platform :ios do

  desc "Build and upload to TestFlight"
  lane :beta do

    match(
      type: "appstore",
      readonly: true,
      git_url: "https://github.com/LukovicNikola/syndicore-certificates.git",
      app_identifier: "com.syndicore.ios"
    )

    update_code_signing_settings(
      use_automatic_signing: false,
      path: "Syndicore.xcodeproj",
      team_id: "QM5HHVW582",
      bundle_identifier: "com.syndicore.ios",
      profile_name: "match AppStore com.syndicore.ios",
      code_sign_identity: "Apple Distribution"
    )

    increment_build_number(
      build_number: ENV["BUILD_NUMBER"] || "1"
    )

    build_app(
      scheme: "Syndicore",
      configuration: "Release",
      export_method: "app-store"
    )

    upload_to_testflight(
      skip_waiting_for_build_processing: true,
      api_key_path: "fastlane/api_key.json"
    )

  end

end